generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum AuditAction {
  USER_REGISTERED
  USER_LOGGED_IN
  USER_LOGGED_OUT
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  ADMIN_SEEDED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  lastLogoutAt DateTime?
  tasks        Task[]
  sessions     Session[]
  auditLogs    AuditLog[]
}

model Session {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime  @default(now())
  ipAddress  String?
  userAgent  String?
  auditLogs  AuditLog[]
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  message    String
  createdAt   DateTime   @default(now())
  ipAddress  String?
  userAgent  String?
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId  String?
  session    Session?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}
